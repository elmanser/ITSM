# =============================================================================
# ITSM Intelligent Platform — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# --- GLPI + MariaDB ---
GLPI_DB_HOST=mariadb
GLPI_DB_NAME=glpi
GLPI_DB_USER=glpi
GLPI_DB_PASSWORD=your_glpi_db_password
MARIADB_ROOT_PASSWORD=your_root_password
MARIADB_DATABASE=glpi
MARIADB_USER=glpi
MARIADB_PASSWORD=your_glpi_db_password

# --- PostgreSQL Data Warehouse ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=itsm_dw
POSTGRES_USER=itsm
POSTGRES_PASSWORD=your_postgres_password

# --- Kafka ---
KAFKA_BROKER=kafka:29092
KAFKA_TOPIC_RAW=itsm.tickets.raw
KAFKA_TOPIC_ENRICHED=itsm.tickets.enriched
KAFKA_GROUP_ID=itsm-consumer-group

# --- GLPI API (get tokens from GLPI → Setup → General → API) ---
GLPI_BASE_URL=http://glpi:80/apirest.php
GLPI_APP_TOKEN=your_glpi_app_token_here
GLPI_USER_TOKEN=your_glpi_user_token_here

# --- Airflow ---
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://itsm:your_postgres_password@postgres:5432/airflow_db
AIRFLOW__CORE__FERNET_KEY=generate_with_python_-c_"from_cryptography.fernet_import_Fernet;print(Fernet.generate_key().decode())"
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__WEBSERVER__SECRET_KEY=your_airflow_secret_key
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=your_admin_password

# --- FastAPI ---
API_HOST=0.0.0.0
API_PORT=8000
ML_MODEL_PATH=/app/models/model.joblib

# --- Streamlit ---
STREAMLIT_SERVER_PORT=8501
